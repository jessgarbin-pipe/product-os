{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/monitoring-context.sh",
            "timeout": 5,
            "statusMessage": "Carregando contexto..."
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/monitoring-context.sh",
            "timeout": 5,
            "statusMessage": "Restaurando contexto..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"Sessão compactada. Skills em .claude/skills/. Agents em .claude/agents/. Use /monitoring-snapshot para resumo executivo.\"}}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-write.sh",
            "timeout": 5,
            "statusMessage": "Validando arquivo..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Se o comando executado foi uma query ao Pendo (activityQuery, guideMetrics, etc.) ou processamento de CSV do Movidesk, verifique: (1) os dados retornados cobrem o período correto? (2) há anomalias óbvias nos números (zeros, valores negativos, NaN)? (3) o N da amostra é suficiente para conclusões? Se houver problemas, avise o PM. Dados do comando: $ARGUMENTS",
            "model": "claude-haiku",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-stop.sh",
            "timeout": 10,
            "statusMessage": "Verificando cadências..."
          }
        ]
      }
    ]
  }
}
